<Window x:Class="ExamsManagement.MainWindow"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Student Marks Management System" 
        Height="800" 
        Width="1200"
        WindowStartupLocation="CenterScreen">

    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#ECF0F1" Offset="0"/>
            <GradientStop Color="#BDC3C7" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" 
                Background="{StaticResource PrimaryColor}" 
                Padding="25"
                CornerRadius="10"
                Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Student Marks Management" 
                          FontSize="36" 
                          FontWeight="Bold" 
                          Foreground="White"
                          HorizontalAlignment="Center"/>
                <TextBlock Text="Complete CRUD Operations with Real-time Statistics" 
                          FontSize="15" 
                          Foreground="#BDC3C7"
                          HorizontalAlignment="Center"
                          Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- Statistics Cards -->
        <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,20">
            <Border Style="{StaticResource Card}" Background="#27AE60">
                <StackPanel>
                    <TextBlock Text="Total Students" 
                              FontSize="14" 
                              Foreground="White" 
                              FontWeight="SemiBold"
                              HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtTotalStudents" 
                              Text="0" 
                              FontSize="36" 
                              Foreground="White" 
                              FontWeight="Bold"
                              HorizontalAlignment="Center"
                              Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Background="#3498DB">
                <StackPanel>
                    <TextBlock Text="Average Mark" 
                              FontSize="14" 
                              Foreground="White" 
                              FontWeight="SemiBold"
                              HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtAverageMark" 
                              Text="0.0" 
                              FontSize="36" 
                              Foreground="White" 
                              FontWeight="Bold"
                              HorizontalAlignment="Center"
                              Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Background="#E74C3C">
                <StackPanel>
                    <TextBlock Text="Highest Mark" 
                              FontSize="14" 
                              Foreground="White" 
                              FontWeight="SemiBold"
                              HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtHighestMark" 
                              Text="0" 
                              FontSize="36" 
                              Foreground="White" 
                              FontWeight="Bold"
                              HorizontalAlignment="Center"
                              Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Input Form -->
        <GroupBox Grid.Row="2" 
                 Header="Student Information Form" 
                 Style="{StaticResource ModernGroupBox}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="15"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Row 1: Input Fields -->
                <Label Content="Student Number:" 
                      Grid.Row="0" Grid.Column="0" 
                      Style="{StaticResource ModernLabel}"
                      Margin="0,0,10,0"/>
                <TextBox x:Name="txtStudentNumber" 
                        Grid.Row="0" Grid.Column="1" 
                        Style="{StaticResource ModernTextBox}"
                        MaxLength="50"/>

                <Label Content="Mark (0-100):" 
                      Grid.Row="0" Grid.Column="3" 
                      Style="{StaticResource ModernLabel}"
                      Margin="0,0,10,0"/>
                <TextBox x:Name="txtMark" 
                        Grid.Row="0" Grid.Column="4" 
                        Style="{StaticResource ModernTextBox}"
                        MaxLength="3"/>

                <Label Content="Grade:" 
                      Grid.Row="0" Grid.Column="6" 
                      Style="{StaticResource ModernLabel}"
                      Margin="0,0,10,0"/>
                <Border Grid.Row="0" Grid.Column="7"
                        Background="#F8F9FA"
                        BorderBrush="#BDC3C7"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="8,6"
                        Height="38">
                    <TextBlock x:Name="txtGrade" 
                              Text=""
                              FontSize="14"
                              FontWeight="Bold"
                              Foreground="{StaticResource PrimaryColor}"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Left"/>
                </Border>

                <!-- Row 2: Action Buttons -->
                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="8" 
                           Orientation="Horizontal" 
                           HorizontalAlignment="Center"
                           Margin="0,5,0,0">
                    <Button Content="Add" 
                           Style="{StaticResource PrimaryButton}"
                           Click="btnAdd_Click"
                           Width="140"
                           Margin="5"/>
                    <Button Content="Update" 
                           Style="{StaticResource SecondaryButton}"
                           Click="btnUpdate_Click"
                           Width="140"
                           Margin="5"/>
                    <Button Content="Delete" 
                           Style="{StaticResource DangerButton}"
                           Click="btnDelete_Click"
                           Width="140"
                           Margin="5"/>
                    <Button Content="Clear" 
                           Style="{StaticResource ModernButton}"
                           Click="btnClear_Click"
                           Width="140"
                           Margin="5"
                           Background="#95A5A6"/>
                    <Button Content="Refresh" 
                           Style="{StaticResource WarningButton}"
                           Click="btnRefresh_Click"
                           Width="140"
                           Margin="5"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Data Grid -->
        <GroupBox Grid.Row="3" 
                 Header="All Student Records" 
                 Style="{StaticResource ModernGroupBox}"
                 Margin="0,20,0,0">
            <DataGrid x:Name="dgMarks" 
                     Style="{StaticResource ModernDataGrid}"
                     IsReadOnly="True"
                     SelectionChanged="dgMarks_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80"/>
                    <DataGridTextColumn Header="Student Number" Binding="{Binding StudentNumber}" Width="*" MinWidth="200"/>
                    <DataGridTextColumn Header="Mark" Binding="{Binding MarkValue}" Width="120"/>
                    <DataGridTextColumn Header="Grade" Binding="{Binding Grade}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
    </Grid>
</Window>
